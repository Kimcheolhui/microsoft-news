# Required for database operations (also set as GitHub Actions secret)
DATABASE_URL=postgresql://user:password@localhost:5432/azure_ingest

# Optional
LOG_LEVEL=INFO

# HTTP retry settings
HTTP_MAX_RETRIES=3
HTTP_BACKOFF_FACTOR=0.5
HTTP_TIMEOUT=30

# Engine retry settings
ENGINE_MAX_RETRIES=2

# Monitoring
CONSECUTIVE_FAILURE_THRESHOLD=3
