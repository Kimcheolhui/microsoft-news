# Required for database operations (also set as GitHub Actions secret)
DATABASE_URL=postgresql://user:password@localhost:5432/azure_ingest

# Optional
LOG_LEVEL=INFO

# HTTP retry settings
HTTP_MAX_RETRIES=3
HTTP_BACKOFF_FACTOR=0.5
HTTP_TIMEOUT=30

# Engine retry settings
ENGINE_MAX_RETRIES=2

# Monitoring
CONSECUTIVE_FAILURE_THRESHOLD=3

# Analysis pipeline — LLM Provider: "openai" or "azure"
LLM_PROVIDER=openai

# OpenAI (when LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1

# Azure OpenAI (when LLM_PROVIDER=azure)
AZURE_OPENAI_API_KEY=your-azure-api-key
AZURE_OPENAI_BASE_URL=https://your-resource.services.ai.azure.com/api/projects/YourProject/openai/v1

ANALYSIS_MODEL=gpt-5.4-mini
MAX_TOKENS_PER_REPORT=8000
